generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}
model User {
  id              String        @id @default(cuid())
  name            String?
  email           String        @unique
  password        String
  role            String        @default("MER_USER")
  claimDepartment String?
  isActive        Boolean       @default(true)
  priority        Int?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  airRequests     AirRequest[]
  approvals       ApprovalLog[]
  attachments     RequestAttachment[]
  claimApprovals  ClaimApproval[]
}
model MasterBrand {
  id       String  @id @default(cuid())
  name     String  @unique
  isActive Boolean @default(true)
}
model MasterBU {
  id       String  @id @default(cuid())
  name     String  @unique
  isActive Boolean @default(true)
}
model MasterDescription {
  id            String  @id @default(cuid())
  name          String  @unique
  weightPerUnit Float   @default(0)
  isActive      Boolean @default(true)
}
model MasterGMTType {
  id       String  @id @default(cuid())
  name     String  @unique
  isActive Boolean @default(true)
}
model MasterPort {
  id        String   @id @default(cuid())
  country   String
  port      String   @unique
  ratePerKg Float    @default(0)
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt
}
model AirRequest {
  id               String           @id @default(cuid())
  documentNo       String           @unique
  brandName        String
  buName           String
  status           String           @default("DRAFT")
  claimDepartment  String?
  rejectionReason  String?
  createdById      String
  createdBy        User             @relation(fields: [createdById], references: [id])
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  items            AirRequestItem[]
  approvalLogs     ApprovalLog[]
  attachments      RequestAttachment[]
  invoiceNo        String?
  actualAirFreight Float?
  bookingDate      DateTime?
  airline          String?
}
model ClaimApproval {
  id        String         @id @default(cuid())
  itemId    String
  item      AirRequestItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  userId    String
  user      User           @relation(fields: [userId], references: [id])
  role      String
  createdAt DateTime       @default(now())

  @@unique([itemId, userId])
}

model AirRequestItem {
  id                   String     @id @default(cuid())
  requestId            String
  request              AirRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  style                String
  so                   String
  customerPO           String?
  description          String?
  gmtType              String?
  originalShipmentDate DateTime?
  planShipmentDate     DateTime?
  qtyOriginalShipment  Int
  qtyRequestAir        Int
  itemStatus           String    @default("PENDING")
  itemComment          String?
  reasonDelay          String
  factory              String
  country              String
  port                 String
  grossWeight          Float?
  airFreight           Float?
  marketRatePerKg      Float?
  actualAirFreight     Float?
  claimDepartment      String?
  invoiceNo            String?
  bookingDate          DateTime?
  claimApprovals       ClaimApproval[]
}
model ApprovalLog {
  id         String     @id @default(cuid())
  requestId  String
  request    AirRequest @relation(fields: [requestId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  userId     String
  user       User       @relation(fields: [userId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  action     String
  fromStatus String
  toStatus   String
  comment    String?
  createdAt  DateTime   @default(now())
}

model RequestAttachment {
  id           String     @id @default(cuid())
  requestId    String
  request      AirRequest @relation(fields: [requestId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  itemId       String?
  uploadedById String
  uploadedBy   User       @relation(fields: [uploadedById], references: [id], onUpdate: NoAction, onDelete: NoAction)
  fileName     String
  filePath     String
  fileSize     Int
  mimeType     String
  claimDept    String?
  createdAt    DateTime   @default(now())
}
